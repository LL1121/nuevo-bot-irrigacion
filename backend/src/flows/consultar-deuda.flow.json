{
  "version": "3.1",
  "screens": [
    {
      "id": "INPUT",
      "title": "Consultar Deuda",
      "terminal": false,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "form_input",
            "children": [
              {
                "type": "TextHeading",
                "text": "Consultar tu deuda"
              },
              {
                "type": "TextBody",
                "text": "Seleccioná con qué dato querés consultar y luego ingresá el número correspondiente."
              },
              {
                "type": "RadioButtonsGroup",
                "label": "Tipo de consulta",
                "name": "tipo_consulta",
                "required": true,
                "data-source": [
                  { "id": "dni",    "title": "DNI / CUIT" },
                  { "id": "padron", "title": "Número de Padrón" }
                ]
              },
              {
                "type": "TextInput",
                "label": "Ingresá el número",
                "name": "input_valor",
                "required": true,
                "input-type": "number",
                "helper-text": "Sin puntos ni guiones (ej: 28456123)"
              },
              {
                "type": "Footer",
                "label": "Consultar",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "tipo_consulta": "${form_input.tipo_consulta}",
                    "input_valor":   "${form_input.input_valor}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "RESULTS",
      "title": "Detalle de Deuda",
      "terminal": true,
      "data": {
        "titular":    { "type": "string", "__example__": "María González" },
        "cuit":       { "type": "string", "__example__": "27-12345678-3" },
        "hectareas":  { "type": "string", "__example__": "5.00" },
        "hijuela":    { "type": "string", "__example__": "Hijuela Norte" },
        "capital":    { "type": "string", "__example__": "$12.500,00" },
        "interes":    { "type": "string", "__example__": "$1.875,00" },
        "apremio":    { "type": "string", "__example__": "$0,00" },
        "eventuales": { "type": "string", "__example__": "$250,00" },
        "total":      { "type": "string", "__example__": "$14.625,00" },
        "link_pago":  { "type": "string", "__example__": "https://epagos.mendoza.gov.ar/pago/123456" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [

          {
            "type": "TextHeading",
            "text": "Titular"
          },
          {
            "type": "TextBody",
            "text": "${data.titular}"
          },
          {
            "type": "TextCaption",
            "text": "CUIT/DNI: ${data.cuit}"
          },

          {
            "type": "TextSubheading",
            "text": "────────────────────"
          },

          {
            "type": "TextHeading",
            "text": "Campo"
          },
          {
            "type": "TextBody",
            "text": "Hectáreas: ${data.hectareas}"
          },
          {
            "type": "TextBody",
            "text": "Hijuela: ${data.hijuela}"
          },

          {
            "type": "TextSubheading",
            "text": "────────────────────"
          },

          {
            "type": "TextHeading",
            "text": "Desglose de deuda"
          },
          {
            "type": "TextBody",
            "text": "Capital:     ${data.capital}"
          },
          {
            "type": "TextBody",
            "text": "Interés:     ${data.interes}"
          },
          {
            "type": "TextBody",
            "text": "Apremio:     ${data.apremio}"
          },
          {
            "type": "TextBody",
            "text": "Eventuales:  ${data.eventuales}"
          },

          {
            "type": "TextSubheading",
            "text": "────────────────────"
          },

          {
            "type": "TextHeading",
            "text": "💵 TOTAL A PAGAR: ${data.total}"
          },
          {
            "type": "TextCaption",
            "text": "💡 Si pagás el total de la deuda, tenés un 50% de descuento en intereses."
          },

          {
            "type": "Footer",
            "label": "Ir a Pagar Deuda",
            "on-click-action": {
              "name": "open_url",
              "url":  "${data.link_pago}"
            }
          }
        ]
      }
    }
  ]
}
