  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "sentry:upload-sourcemaps": "sentry-cli releases new $SENTRY_RELEASE || true && sentry-cli releases files $SENTRY_RELEASE upload-sourcemaps ./dist --validate --url-prefix '~/'; sentry-cli releases finalize $SENTRY_RELEASE",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:critical": "vitest run src/utils/messageOrder.test.ts src/services/messageQueue.test.ts src/services/optimisticUpdates.test.ts src/utils/messageCachePolicy.test.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "release:check": "npm run test:critical && npm run build",
    "release:check:full": "npm run lint && npm run test && npm run build"
  },
