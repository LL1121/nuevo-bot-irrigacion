# ═══════════════════════════════════════════════════════════════════════════════
# 🎨 FRONTEND - VARIABLES DE ENTORNO
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copiar este archivo a .env.local (desarrollo) o .env.production (producción)
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# 🔌 API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# URL base de la API
# Dev: http://localhost:3000
# Prod: https://whatsapp.irrigacionmalargue.net
VITE_API_URL=http://localhost:3000

# URL del WebSocket (Socket.io)
# Dev: http://localhost:3000
# Prod: https://whatsapp.irrigacionmalargue.net
VITE_SOCKET_URL=http://localhost:3000

# URL base completa para redirects
# Dev: http://localhost:3000
# Prod: https://whatsapp.irrigacionmalargue.net
VITE_BASE_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 AUTH CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Clave local storage para token JWT
VITE_TOKEN_KEY=irrigacion_bot_token

# Clave local storage para datos del operador
VITE_OPERADOR_KEY=irrigacion_bot_operator

# Tiempo de expiración de sesión en milisegundos
# Default: 3600000 (1 hora)
VITE_JWT_EXPIRY_MS=3600000

# ═══════════════════════════════════════════════════════════════════════════════
# ⏱️ TIMEOUTS & LIMITS
# ═══════════════════════════════════════════════════════════════════════════════

# Timeout para requests HTTP en milisegundos
# Default: 30000 (30 segundos)
VITE_REQUEST_TIMEOUT_MS=30000

# Delay para reconectar Socket.io en milisegundos
# Default: 1000 (1 segundo)
VITE_SOCKET_RECONNECT_DELAY_MS=1000

# Intentos de reconexión para Socket.io
# Default: 5 intentos
VITE_SOCKET_RECONNECT_ATTEMPTS=5

# Timeout de sesión en milisegundos
# Default: 86400000 (24 horas)
VITE_SESSION_TIMEOUT_MS=86400000

# ═══════════════════════════════════════════════════════════════════════════════
# 🚀 FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

# Habilitar logging en consola
# Valores: true, false
VITE_ENABLE_LOGGING=true

# Habilitar Sentry para error tracking
# Valores: true, false
VITE_ENABLE_SENTRY=false

# DSN de Sentry (si VITE_ENABLE_SENTRY=true)
VITE_SENTRY_DSN=

# Ambiente Sentry
# Valores: development, staging, production
VITE_SENTRY_ENVIRONMENT=development

# ═══════════════════════════════════════════════════════════════════════════════
# 🎯 APLICACIÓN
# ═══════════════════════════════════════════════════════════════════════════════

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# Nombre de la aplicación
VITE_APP_NAME=Bot Irrigación

# Modo debug
# Valores: true, false
VITE_DEBUG_MODE=false

# ═══════════════════════════════════════════════════════════════════════════════
# 📊 DATOS MOCK (OPCIONAL - solo para desarrollo)
# ═══════════════════════════════════════════════════════════════════════════════

# Usar datos mock en lugar de API real
# Valores: true, false
VITE_USE_MOCK_DATA=false

# ═══════════════════════════════════════════════════════════════════════════════
# 📝 NOTAS
# ═══════════════════════════════════════════════════════════════════════════════
#
# DESARROLLO (.env.local):
#   VITE_API_URL=http://localhost:3000
#   VITE_SOCKET_URL=http://localhost:3000
#   VITE_ENABLE_LOGGING=true
#   VITE_DEBUG_MODE=true
#
# PRODUCCIÓN (.env.production):
#   VITE_API_URL=https://whatsapp.irrigacionmalargue.net
#   VITE_SOCKET_URL=https://whatsapp.irrigacionmalargue.net
#   VITE_ENABLE_LOGGING=false
#   VITE_DEBUG_MODE=false
#
# ═══════════════════════════════════════════════════════════════════════════════
