# Frontend Environment Variables Example
# Copy this file to .env.local for development or .env.production for production

# API Configuration
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# Auth Configuration
VITE_TOKEN_KEY=token
VITE_OPERADOR_KEY=operador
VITE_JWT_EXPIRY_MS=3600000

# Feature Flags
VITE_ENABLE_LOGGING=true
VITE_ENABLE_SENTRY=false
VITE_SENTRY_DSN=

# Timeouts & Limits
VITE_REQUEST_TIMEOUT_MS=30000
VITE_SOCKET_RECONNECT_DELAY_MS=1000
VITE_SOCKET_RECONNECT_ATTEMPTS=5
VITE_SESSION_TIMEOUT_MS=86400000
