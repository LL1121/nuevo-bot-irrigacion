PORT=3000
WEBHOOK_VERIFY_TOKEN=tu_token_secreto_aqui
WHATSAPP_TOKEN=tu_whatsapp_access_token
WHATSAPP_PHONE_ID=tu_phone_number_id
# Base de Datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=irrigacion

# JWT
JWT_SECRET=tu_secret_key_super_seguro_aqui
JWT_EXPIRY=8h

# Frontend
FRONTEND_URL=http://localhost:5173

# AWS S3 Backups
AWS_ACCESS_KEY_ID=tu_aws_access_key
AWS_SECRET_ACCESS_KEY=tu_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=irrigacion-backups

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_CRON_SCHEDULE=0 2 */3 * *
BACKUP_RETENTION_DAYS=7

# Redis Caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
NODE_ENV=development
