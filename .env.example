# ═══════════════════════════════════════════════════════════════════════════════
# 🤖 BOT DE IRRIGACIÓN - CONFIGURACIÓN DE ENTORNO
# ═══════════════════════════════════════════════════════════════════════════════
# 
# ⚠️ IMPORTANTE: Nunca commitear este archivo con valores reales a Git
# Copiar .env.example a .env y llenar con credenciales reales
#
# Para desarrollo local: npm start
# Para producción con Docker: docker-compose up -d
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 SERVIDOR
# ═══════════════════════════════════════════════════════════════════════════════

# Entorno de ejecución
# Valores: development, production
NODE_ENV=production

# Puerto donde escucha el servidor
PORT=3000

# URL base de la aplicación
# Importante: Usada para webhooks y redirects
BASE_URL=https://chat.irrigacionmalargue.net

# ═══════════════════════════════════════════════════════════════════════════════
# 🗄️ POSTGRESQL - BASE DE DATOS
# ═══════════════════════════════════════════════════════════════════════════════

# Host del servidor PostgreSQL
# Ejemplos: localhost, 192.168.1.100, db.ejemplo.com
DB_HOST=localhost

# Puerto de PostgreSQL
# Default: 5432
DB_PORT=5432

# Usuario de PostgreSQL
# Recomendado: NO usar 'postgres' en producción
DB_USER=postgres

# Contraseña del usuario PostgreSQL
# ⚠️ Usar contraseña segura (mínimo 16 caracteres)
DB_PASSWORD=tu_password_seguro_aqui_16_caracteres_minimo

# Nombre de la base de datos
# Default: irrigacion_bot
DB_NAME=irrigacion_bot

# Pool de conexiones (opcional)
# Máximo: 50 (optimizado para 50+ usuarios concurrentes)
DB_POOL_SIZE=50

# Timeout de inactividad en milisegundos
DB_IDLE_TIMEOUT=60000

# Timeout de conexión en milisegundos
DB_CONNECT_TIMEOUT=10000

# ═══════════════════════════════════════════════════════════════════════════════
# 📱 WHATSAPP CLOUD API (Meta)
# ═══════════════════════════════════════════════════════════════════════════════

# Token de acceso de WhatsApp Business API
# Obtener en: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# ⚠️ Muy importante: Mantener secreto
WHATSAPP_TOKEN=tu_token_de_meta_aqui_ESTE_ES_LARGO_Y_ENCRIPTADO

# ID del número de teléfono (Phone Number ID)
# Formato: número sin caracteres especiales
# Obtener en: Facebook Business Manager > WhatsApp Business Account
WHATSAPP_PHONE_NUMBER_ID=1234567890123456

# ID de la cuenta de negocio (Business Account ID)
# Obtener en: Facebook Business Manager
WHATSAPP_BUSINESS_ACCOUNT_ID=1234567890123456

# Token de verificación del webhook
# Valor personalizado para verificar autenticidad
# Recomendado: String aleatorio de 32+ caracteres
WEBHOOK_VERIFY_TOKEN=tu_token_de_verificacion_secreto_aqui

# Secret de la aplicación (para X-Hub-Signature)
# Obtener en: Facebook App Settings
WEBHOOK_APP_SECRET=tu_app_secret_aqui

# ═══════════════════════════════════════════════════════════════════════════════
# 🔴 REDIS - CACHÉ Y SESIONES
# ═══════════════════════════════════════════════════════════════════════════════

# Host del servidor Redis
# Para Docker Compose: 'redis' (nombre del servicio)
# Para local: 'localhost' o '127.0.0.1'
REDIS_HOST=redis

# Puerto de Redis
# Default: 6379
REDIS_PORT=6379

# Contraseña de Redis (si está protegido)
# Dejar vacío si no tiene contraseña
REDIS_PASSWORD=

# URL completa de Redis (alternativa a HOST/PORT/PASSWORD)
# Usar si prefieres una URL única
# Ejemplo: redis://user:password@localhost:6379
REDIS_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 AUTENTICACIÓN - JWT
# ═══════════════════════════════════════════════════════════════════════════════

# Secret key para firmar JWT tokens
# ⚠️ CRÍTICO: Usar string aleatorio fuerte (32+ caracteres)
# Generar con: openssl rand -base64 32
JWT_SECRET=tu_jwt_secret_super_seguro_y_aleatorio_aqui

# Tiempo de expiración del token
# Valores comunes: 8h, 24h, 7d
# Default: 8h (recomendado para operadores)
JWT_EXPIRY=8h

# Algoritmo de encriptación JWT
# Default: HS256
JWT_ALGORITHM=HS256

# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 OPTIMIZACIONES Y PERFORMANCE
# ═══════════════════════════════════════════════════════════════════════════════

# Número máximo de browsers en pool de Puppeteer
# Default: 3 (balance entre memory y performance)
# Rango: 2-8 (según RAM disponible)
MAX_BROWSERS=3

# Tiempo máximo de espera para scraping (ms)
# Default: 30000 (30 segundos)
SCRAPE_TIMEOUT=30000

# ═══════════════════════════════════════════════════════════════════════════════
# 📊 LOGGING Y MONITOREO
# ═══════════════════════════════════════════════════════════════════════════════

# Nivel de log
# Valores: debug, info, warn, error
# Default: info (recomendado para producción)
LOG_LEVEL=info

# Habilitar logs en archivos
# Default: true (recomendado en producción)
LOG_TO_FILE=true

# Ruta de archivos de log
# Default: ./logs
LOG_DIR=./logs

# ═══════════════════════════════════════════════════════════════════════════════
# 🚨 SENTRY - ERROR TRACKING (Opcional)
# ═══════════════════════════════════════════════════════════════════════════════

# DSN de Sentry para monitoreo de errores
# Obtener en: https://sentry.io (crear proyecto Node.js)
# Dejar vacío para desactivar
SENTRY_DSN=

# Ambiente en Sentry
# Values: development, staging, production
SENTRY_ENVIRONMENT=production

# ═══════════════════════════════════════════════════════════════════════════════
# ☁️ AWS - BACKUPS Y STORAGE (Opcional)
# ═══════════════════════════════════════════════════════════════════════════════

# Región de AWS
# Ejemplo: us-east-1, sa-east-1
AWS_REGION=us-east-1

# Bucket S3 para backups
AWS_S3_BUCKET=irrigacion-backups

# Access Key ID de AWS
AWS_ACCESS_KEY_ID=

# Secret Access Key de AWS
AWS_SECRET_ACCESS_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# 💾 BACKUPS - CONFIGURACIÓN
# ═══════════════════════════════════════════════════════════════════════════════

# Habilitar backups automáticos
# Default: true
BACKUP_ENABLED=true

# Schedule en formato cron para backups
# Ejemplo: "0 2 */3 * *" = cada 3 días a las 2 AM
BACKUP_CRON_SCHEDULE=0 2 */3 * *

# Retención de backups en días
# Default: 7 días
BACKUP_RETENTION_DAYS=7

# Destino de backups
# Valores: local, s3, both
# Default: local
BACKUP_DESTINATION=local

# ═══════════════════════════════════════════════════════════════════════════════
# 🏥 HEALTH CHECK
# ═══════════════════════════════════════════════════════════════════════════════

# Intervalo entre health checks (ms)
# Default: 30000 (30 segundos)
HEALTH_CHECK_INTERVAL=30000

# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️ NOTAS IMPORTANTES
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. SEGURIDAD:
#    - Nunca commitear credenciales reales en Git
#    - Usar secretos en variables de entorno del servidor
#    - Cambiar regularmente: JWT_SECRET, WEBHOOK_VERIFY_TOKEN
#
# 2. DESARROLLO vs PRODUCCIÓN:
#    Dev:  NODE_ENV=development, LOG_LEVEL=debug
#    Prod: NODE_ENV=production, LOG_LEVEL=info
#
# 3. POSTGRESQL:
#    - En producción, usar host externo (no localhost)
#    - Pool size: 50 para app, 10 para dev
#    - Usar contraseña segura (minimo 16 caracteres)
#
# 4. WHATSAPP:
#    - Token se regenera cada 60 días
#    - Guardar credenciales en secrets manager
#    - Probar webhook con ngrok en desarrollo
#
# 5. REDIS:
#    - En Docker: usar nombre del servicio 'redis'
#    - En local: usar 'localhost'
#    - Con contraseña: redis://:password@host:port
#
# 6. DOCKER:
#    - Las variables se cargan desde .env
#    - Cambiar en .env y hacer docker-compose up -d
#
# ═══════════════════════════════════════════════════════════════════════════════
