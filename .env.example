# ======================================
# BOT DE IRRIGACIÓN - CONFIGURACIÓN
# ======================================

# ============ Node.js ============
NODE_ENV=production
PORT=3000
BASE_URL=https://chat.irrigacionmalargue.net

# ============ PostgreSQL ============
# Base de datos existente en el servidor
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_NAME=irrigacion_bot

# ============ WhatsApp API ============
WHATSAPP_TOKEN=tu_token_aqui
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui
WHATSAPP_BUSINESS_ACCOUNT_ID=tu_business_account_id_aqui
WEBHOOK_VERIFY_TOKEN=tu_webhook_verify_token_aqui

# ============ Redis ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ Sentry (Opcional) ============
SENTRY_DSN=

# ============ Optimizaciones ============
MAX_BROWSERS=3
DB_CONNECTION_LIMIT=50

# ============ JWT ============
JWT_SECRET=tu_secret_key_super_seguro_aqui
JWT_EXPIRY=8h
AWS_REGION=us-east-1
AWS_S3_BUCKET=irrigacion-backups

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_CRON_SCHEDULE=0 2 */3 * *
BACKUP_RETENTION_DAYS=7

# Redis Caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Webhook & Sentry
WEBHOOK_APP_SECRET=
WEBHOOK_VERIFY_TOKEN=tu_token_secreto_aqui
SENTRY_DSN=

# Redis full URL (optional)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
NODE_ENV=development
