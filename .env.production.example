# ═══════════════════════════════════════════════════════════════════════════════
# Irrigación Bot - Configuración para PRODUCCIÓN en Ubuntu Server
# USAR PARA SERVIDOR: chat.irrigacionmalargue.net (Cloudflare Tunnel)
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# 1. CONFIGURACIÓN DEL SERVIDOR NODE.JS
# ═══════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# ═══════════════════════════════════════════════════════════════════════════════
# 2. CONFIGURACIÓN DE BASE DE DATOS POSTGRESQL
# ═══════════════════════════════════════════════════════════════════════════════

# Cliente de base de datos (PostgreSQL en contenedor)
DB_CLIENT=pg

# Host del contenedor Docker
DB_HOST=db
DB_PORT=5432

# Credenciales PostgreSQL (CAMBIAR EN PRODUCCIÓN)
DB_USER=postgres
DB_PASSWORD=irrigacion_secret

# Nombre de la base de datos
DB_NAME=irrigacion_db

# Pool de conexiones (optimizado para producción)
DB_POOL_MIN=5
DB_POOL_MAX=20

# ═══════════════════════════════════════════════════════════════════════════════
# 3. META API / WHATSAPP
# ═══════════════════════════════════════════════════════════════════════════════

# Token de acceso Meta Long-Lived (NUNCA expira - Sistema User)
# Obtener: Meta Business Suite > Settings > System Users > Create
META_ACCESS_TOKEN=EAAB...

# ID del número de teléfono WhatsApp
WHATSAPP_PHONE_NUMBER_ID=907958582401690

# Secret de la aplicación Meta
META_APP_SECRET=b1f32f59feeb2e9b21601e756f4025fd

# Token para verificar webhooks de Meta
WEBHOOK_VERIFY_TOKEN=lautaro_clave_secreta_123

# ═══════════════════════════════════════════════════════════════════════════════
# 4. AUTENTICACIÓN JWT
# ═══════════════════════════════════════════════════════════════════════════════

# Secret para firmar tokens JWT (CAMBIAR EN PRODUCCIÓN)
JWT_SECRET=tu_secret_jwt_super_seguro_prod_2026

# Tiempo de expiración del token
JWT_EXPIRY=8h

# ═══════════════════════════════════════════════════════════════════════════════
# 5. REDIS CACHE
# ═══════════════════════════════════════════════════════════════════════════════

# Host de Redis (contenedor Docker)
REDIS_HOST=redis
REDIS_PORT=6379

# Contraseña de Redis (CAMBIAR EN PRODUCCIÓN)
REDIS_PASSWORD=redis_secret

# ═══════════════════════════════════════════════════════════════════════════════
# 6. LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

# Nivel de log (debug, info, warn, error)
LOG_LEVEL=info

# Escribir logs a archivo
LOG_TO_FILE=true
LOG_DIR=/app/logs

# ═══════════════════════════════════════════════════════════════════════════════
# 7. URLs DEL SERVIDOR (Cloudflare Tunnel)
# ═══════════════════════════════════════════════════════════════════════════════

# URL base del API
API_URL=https://chat.irrigacionmalargue.net/api

# URL del webhook para recibir mensajes de Meta
WEBHOOK_URL=https://chat.irrigacionmalargue.net/webhook

# ═══════════════════════════════════════════════════════════════════════════════
# 8. CLOUDFLARE TUNNEL
# ═══════════════════════════════════════════════════════════════════════════════

# Token del túnel Cloudflare (generar en dashboard.cloudflare.com)
TUNNEL_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# 9. PUPPETEER (Web Scraping)
# ═══════════════════════════════════════════════════════════════════════════════

# No descargar Chromium en Docker (ya incluido)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Máximo de navegadores simultáneos
MAX_BROWSERS=3

# ═══════════════════════════════════════════════════════════════════════════════
# 10. VARIABLES OPCIONALES
# ═══════════════════════════════════════════════════════════════════════════════

# Sentry para monitoreo de errores
SENTRY_DSN=

# Email para alertas
ALERT_EMAIL=

# Zona horaria
TZ=America/Argentina/Buenos_Aires
